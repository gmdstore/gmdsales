{
  "entities": {
    "product": {
      "title": "Product",
      "description": "Product sold in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique product ID" },
        "name": { "type": "string", "description": "Product name" },
        "sku": { "type": "string", "description": "Stock Keeping Unit" },
        "hpp": { "type": "number", "description": "Harga Pokok Pembelian / Cost of Goods Sold" },
        "price": { "type": "number", "description": "Product selling price" },
        "imageUrl": { "type": "string", "description": "URL of the product image" },
        "group": { "type": "string", "description": "Product category group" },
        "colors": { "type": "array", "description": "Available colors" },
        "sizes": { "type": "array", "description": "Allowed sizes for this product" }
      },
      "required": ["id", "name", "hpp", "price"]
    },
    "stockItem": {
      "title": "StockItem",
      "description": "Inventory stock record for product and color",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Format: `${productId}_${color}`" },
        "productId": { "type": "string", "description": "Reference to the product" },
        "productName": { "type": "string", "description": "Cache of product name" },
        "color": { "type": "string", "description": "Color name" },
        "stocks": { "type": "object", "description": "Size-to-quantity mapping" }
      },
      "required": ["id", "productId", "color", "stocks"]
    },
    "channel": {
      "title": "Channel",
      "description": "Sales channel (e.g. Shopee, WhatsApp)",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Channel ID" },
        "name": { "type": "string", "description": "Channel name" },
        "commissionPercent": { "type": "number", "description": "Commission fee in %" },
        "paymentFeePercent": { "type": "number", "description": "Payment gateway fee in %" },
        "flatProcessingFee": { "type": "number", "description": "Flat processing fee in Rp" },
        "freeShippingSubsidyPercent": { "type": "number", "description": "Free shipping subsidy in %" },
        "freeShippingMaxCap": { "type": "number", "description": "Free shipping maximum cap in Rp" },
        "color": { "type": "string", "description": "Color badge styling" },
        "paymentMethods": { "type": "array", "description": "Allowed payment methods for this channel" }
      },
      "required": ["id", "name", "commissionPercent", "paymentFeePercent", "flatProcessingFee"]
    },
    "autoDiscount": {
      "title": "AutoDiscount",
      "description": "Automatic dynamic discounts configured for store",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Discount ID" },
        "name": { "type": "string", "description": "Discount name" },
        "type": { "type": "string", "enum": ["percent", "nominal"], "description": "Type of discount" },
        "value": { "type": "number", "description": "Percent or nominal value" },
        "channelIds": { "type": "array", "description": "Sales channel IDs or ['all']" },
        "productIds": { "type": "array", "description": "Product IDs or ['all']" },
        "isActive": { "type": "boolean", "description": "Is the discount active" }
      },
      "required": ["id", "name", "type", "value", "channelIds", "productIds", "isActive"]
    },
    "order": {
      "title": "Order",
      "description": "Sales order record with detailed calculations",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique order ID" },
        "orderNumber": { "type": "string", "description": "Unique human order number" },
        "dateTime": { "type": "string", "description": "ISO timestamp" },
        "channelId": { "type": "string", "description": "Associated channel" },
        "paymentMethod": { "type": "string", "description": "Payment method" },
        "products": { "type": "array", "description": "List of ordered products and details" },
        "totalPrice": { "type": "number", "description": "Gross price of order" },
        "totalHpp": { "type": "number", "description": "Total Cost of Goods Sold" },
        "discounts": { "type": "number", "description": "Additional user-entered discounts" },
        "calculatedFees": { "type": "object", "description": "Fees broken down" },
        "netRevenue": { "type": "number", "description": "Net revenue after fees" },
        "netProfit": { "type": "number", "description": "Net profit after fees and hpp" },
        "pencatat": { "type": "string", "description": "Name of Admin recording the transaction" }
      },
      "required": ["id", "orderNumber", "dateTime", "channelId", "paymentMethod", "products", "totalPrice", "netProfit"]
    },
    "settings": {
      "title": "Settings",
      "description": "Global application branding and general configuration settings",
      "type": "object",
      "properties": {
        "brandName": { "type": "string" },
        "brandLogo": { "type": "string" },
        "brandProfile": { "type": "string" },
        "brandFooter": { "type": "string" },
        "appFont": { "type": "string" },
        "appFontWeight": { "type": "string" },
        "paymentMethods": { "type": "array" },
        "pencatatList": { "type": "array" }
      },
      "required": ["brandName"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "product",
      "description": "Managed products list"
    },
    "/stocks/{stockId}": {
      "schema": "stockItem",
      "description": "Managed color/size stocks"
    },
    "/channels/{channelId}": {
      "schema": "channel",
      "description": "Managed sales channels"
    },
    "/autoDiscounts/{discountId}": {
      "schema": "autoDiscount",
      "description": "Dynamic auto discount rules"
    },
    "/orders/{orderId}": {
      "schema": "order",
      "description": "Sales orders recorded"
    },
    "/settings/app": {
      "schema": "settings",
      "description": "Global application settings configuration"
    }
  }
}
